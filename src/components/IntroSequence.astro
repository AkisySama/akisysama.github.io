---
const terminalSequence = [
  {
    command: "journalctl --boot --priority=notice --no-pager",
    output: [
      { text: "Jul 23 09:41:08 kernel: entropy pool synchronized", tone: "muted" },
      { text: "Jul 23 09:41:08 systemd: mounted /dev/ideas on /mnt/archive", tone: "muted" },
      { text: "Jul 23 09:41:09 chronicle[2048]: temporal cache warmed", tone: "success" },
    ],
  },
  {
    command: "npx vectorize ./memory --dimensions=1536 --incremental",
    output: [
      { text: "[01/04] resolving semantic topology ........ done", tone: "muted" },
      { text: "[02/04] calibrating latent coordinates ..... done", tone: "muted" },
      { text: "[03/04] folding narrative tensors .......... done", tone: "muted" },
      { text: "[04/04] committing ephemeral index .......... done", tone: "success" },
    ],
  },
  {
    command: "curl -s localhost:4321/health | jq -C",
    output: [
      { text: '{ "status": "nominal", "signal": 0.9987, "meaning": null }', tone: "json" },
      { text: "handshake complete · observer channel ready", tone: "success" },
    ],
  },
];
---

<section class="intro-sequence" data-intro-sequence aria-label="博客开场动画">
  <div class="intro-stage" data-intro-stage>
    <p class="intro-kicker" aria-hidden="true">A.K. / PRIVATE JOURNAL</p>

    <div class="terminal-window" data-terminal-window>
      <div class="terminal-titlebar" aria-hidden="true">
        <div class="terminal-lights">
          <span></span>
          <span></span>
          <span></span>
        </div>
        <span class="terminal-title">akisy — zsh — 96×45</span>
        <span class="terminal-spacer"></span>
      </div>

      <div class="terminal-body">
        <div class="terminal-session" data-terminal-session>
          <div
            class="terminal-transcript"
            data-terminal-transcript
            aria-label="正在运行系统初始化命令"
          ></div>
          <p class="terminal-command terminal-active-command">
            <span class="terminal-prompt">akisy@journal ~ %</span>
            <span data-command-output></span><span class="terminal-cursor" aria-hidden="true"></span>
          </p>
        </div>
        <p class="terminal-status" data-terminal-status aria-live="polite">awaiting bootstrap signal...</p>
      </div>
    </div>

    <div class="entry-cue" data-entry-cue aria-hidden="true">
      <span class="entry-line"></span>
      <span class="entry-label">SCROLL TO ENTER</span>
    </div>

    <button class="intro-skip" type="button" data-intro-skip>跳过序章</button>
  </div>
</section>

<script is:inline define:vars={{ terminalSequence }}>
  const sleep = (duration) => new Promise((resolve) => window.setTimeout(resolve, duration));

  const setupIntro = () => {
    const intro = document.querySelector("[data-intro-sequence]");
    if (!(intro instanceof HTMLElement) || intro.dataset.bound === "true") return;

    intro.dataset.bound = "true";

    const root = document.documentElement;

    if (root.dataset.intro !== "pending") {
      root.dataset.blogEntered = "true";
      intro.hidden = true;
      return;
    }

    const stage = intro.querySelector("[data-intro-stage]");
    const windowElement = intro.querySelector("[data-terminal-window]");
    const session = intro.querySelector("[data-terminal-session]");
    const transcript = intro.querySelector("[data-terminal-transcript]");
    const commandOutput = intro.querySelector("[data-command-output]");
    const status = intro.querySelector("[data-terminal-status]");
    const skip = intro.querySelector("[data-intro-skip]");
    const reducedMotion = matchMedia("(prefers-reduced-motion: reduce)").matches;

    if (
      !(stage instanceof HTMLElement) ||
      !(windowElement instanceof HTMLElement) ||
      !(session instanceof HTMLElement) ||
      !(transcript instanceof HTMLElement) ||
      !(commandOutput instanceof HTMLElement) ||
      !(status instanceof HTMLElement) ||
      !(skip instanceof HTMLButtonElement)
    ) {
      root.dataset.intro = "seen";
      return;
    }

    let finished = false;
    let cancelled = false;
    let entering = false;
    let touchStartY = 0;
    root.dataset.intro = "playing";
    intro.hidden = false;

    const followCursor = () => {
      session.scrollTop = session.scrollHeight;
    };

    const appendCommand = (command) => {
      const line = document.createElement("p");
      line.className = "terminal-command terminal-command-history";

      const prompt = document.createElement("span");
      prompt.className = "terminal-prompt";
      prompt.textContent = "akisy@journal ~ %";

      const value = document.createElement("span");
      value.textContent = command;
      line.append(prompt, value);
      transcript.append(line);
      followCursor();
    };

    const appendOutput = ({ text, tone }) => {
      const line = document.createElement("p");
      line.className = "terminal-output-line";
      line.dataset.tone = tone;
      line.textContent = text;
      transcript.append(line);
      followCursor();
    };

    const renderCompleteTranscript = () => {
      transcript.replaceChildren();
      for (const step of terminalSequence) {
        appendCommand(step.command);
        for (const output of step.output) appendOutput(output);
      }
    };

    if ("scrollRestoration" in history) history.scrollRestoration = "manual";
    window.scrollTo({ top: 0, behavior: "auto" });

    const updateScrollProgress = () => {
      if (!finished) return;
      const progress = Math.min(window.scrollY / Math.max(window.innerHeight * 0.38, 1), 1);
      stage.style.setProperty("--intro-shift", `${progress * -48}px`);
      stage.style.setProperty("--intro-opacity", String(1 - progress * 0.92));
    };

    const enterBlog = () => {
      if (!finished || entering) return;
      entering = true;
      root.dataset.blogEntered = "true";
      window.removeEventListener("wheel", handleWheel);
      window.removeEventListener("touchstart", handleTouchStart);
      window.removeEventListener("touchend", handleTouchEnd);
      window.removeEventListener("keydown", handleKeydown);
      const blogTop = intro.offsetHeight;
      window.scrollTo({
        top: blogTop,
        behavior: reducedMotion ? "auto" : "smooth",
      });

      if (!reducedMotion) {
        window.setTimeout(() => {
          if (Math.abs(window.scrollY - blogTop) > 2) {
            window.scrollTo({ top: blogTop, behavior: "auto" });
          }
        }, 900);
      }
    };

    const handleWheel = (event) => {
      if (event.deltaY <= 6 || window.scrollY >= intro.offsetHeight) return;
      event.preventDefault();
      enterBlog();
    };

    const handleTouchStart = (event) => {
      touchStartY = event.changedTouches[0]?.clientY ?? 0;
    };

    const handleTouchEnd = (event) => {
      const touchEndY = event.changedTouches[0]?.clientY ?? touchStartY;
      if (touchStartY - touchEndY >= 36) enterBlog();
    };

    const handleKeydown = (event) => {
      if (!["ArrowDown", "PageDown", " "].includes(event.key)) return;
      event.preventDefault();
      enterBlog();
    };

    const finish = (shouldEnter = false) => {
      if (finished) return;
      finished = true;
      commandOutput.textContent = "";
      renderCompleteTranscript();
      transcript.setAttribute("aria-label", "系统初始化完成，博客已就绪");
      status.textContent = "all systems nominal — journal ready";
      intro.classList.add("is-complete");
      root.dataset.intro = "complete";
      window.addEventListener("scroll", updateScrollProgress, { passive: true });
      window.addEventListener("wheel", handleWheel, { passive: false });
      window.addEventListener("touchstart", handleTouchStart, { passive: true });
      window.addEventListener("touchend", handleTouchEnd, { passive: true });
      window.addEventListener("keydown", handleKeydown);

      if (shouldEnter) {
        window.setTimeout(enterBlog, reducedMotion ? 0 : 180);
      }
    };

    skip.addEventListener("click", () => {
      cancelled = true;
      finish(true);
    });

    const play = async () => {
      if (reducedMotion) {
        finish(false);
        return;
      }

      await sleep(520);

      for (let stepIndex = 0; stepIndex < terminalSequence.length; stepIndex += 1) {
        const step = terminalSequence[stepIndex];
        status.textContent = `executing pipeline ${stepIndex + 1}/${terminalSequence.length}`;

        for (const character of step.command) {
          if (cancelled || !intro.isConnected) return;
          commandOutput.textContent += character;
          followCursor();
          await sleep(character === " " ? 34 : 19);
        }

        await sleep(120);
        appendCommand(step.command);
        commandOutput.textContent = "";

        for (const output of step.output) {
          if (cancelled || !intro.isConnected) return;
          appendOutput(output);
          await sleep(170);
        }

        await sleep(130);
      }

      status.textContent = "validating observer channel...";
      await sleep(480);

      if (!cancelled && intro.isConnected) finish(false);
    };

    play();
  };

  document.addEventListener("astro:page-load", setupIntro);
  setupIntro();
</script>

<style>
  :global(html[data-page="home"][data-intro="pending"]),
  :global(html[data-page="home"][data-intro="playing"]) {
    overflow: hidden;
  }

  :global(html[data-page="home"][data-intro="seen"]) .intro-sequence {
    display: none;
  }

  .intro-sequence {
    min-height: 135svh;
    border-bottom: 1px solid var(--color-border);
    background: var(--color-bg);
    color: var(--color-text);
  }

  .intro-stage {
    --intro-shift: 0px;
    --intro-opacity: 1;
    position: sticky;
    top: 0;
    display: grid;
    place-items: center;
    height: 100svh;
    min-height: 620px;
    overflow: hidden;
    opacity: var(--intro-opacity);
    transform: translateY(var(--intro-shift));
    transition: opacity 120ms linear, transform 120ms linear;
  }

  .intro-kicker {
    position: absolute;
    top: 34px;
    left: clamp(24px, 5vw, 72px);
    margin: 0;
    color: var(--color-faint);
    font-size: 0.6rem;
    letter-spacing: 0.2em;
  }

  .terminal-window {
    width: min(84vw, 760px);
    height: min(74svh, 530px);
    min-height: 470px;
    overflow: hidden;
    border: 1px solid #313337;
    border-radius: 11px;
    background: #090b0d;
    box-shadow: 0 28px 80px rgb(0 0 0 / 52%);
    opacity: 0;
    transform: translateY(22px) scale(0.985);
    animation: terminal-enter 900ms cubic-bezier(0.2, 0.75, 0.25, 1) 120ms forwards;
  }

  .terminal-titlebar {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    height: 42px;
    padding: 0 15px;
    border-bottom: 1px solid #282a2d;
    background: #131518;
  }

  .terminal-lights {
    display: flex;
    gap: 8px;
  }

  .terminal-lights span {
    width: 10px;
    height: 10px;
    border: 1px solid #5b5a56;
    border-radius: 50%;
    background: #242528;
  }

  .terminal-title,
  .terminal-status {
    color: #74767a;
    font-family: var(--font-mono);
    font-size: 0.67rem;
  }

  .terminal-spacer {
    min-width: 42px;
  }

  .terminal-body {
    position: relative;
    display: flex;
    flex-direction: column;
    box-sizing: border-box;
    height: calc(100% - 42px);
    min-height: 0;
    padding: 26px 30px 24px;
    font-family: var(--font-mono);
  }

  .terminal-session {
    flex: 1;
    min-height: 0;
    overflow: hidden;
    scrollbar-width: none;
  }

  .terminal-transcript {
    overflow: visible;
  }

  .terminal-command {
    display: flex;
    align-items: center;
    min-height: 22px;
    margin: 0;
    color: #d8d4ca;
    font-size: 0.78rem;
    white-space: pre-wrap;
  }

  .terminal-command-history {
    margin-top: 14px;
  }

  .terminal-command-history:first-child {
    margin-top: 0;
  }

  .terminal-active-command {
    flex: 0 0 auto;
    margin-top: 14px;
  }

  .terminal-prompt {
    flex: 0 0 auto;
    margin-right: 9px;
    color: #8e9a83;
  }

  .terminal-cursor {
    width: 7px;
    height: 1.1em;
    margin-left: 3px;
    background: #bfb7a6;
    animation: cursor-blink 880ms steps(1) infinite;
  }

  .terminal-output-line {
    margin: 4px 0 0;
    color: #777c83;
    font-size: 0.72rem;
    line-height: 1.55;
    white-space: pre-wrap;
  }

  .terminal-output-line[data-tone="success"] {
    color: #8e9a83;
  }

  .terminal-output-line[data-tone="json"] {
    color: #a7a18f;
  }

  .terminal-status {
    margin: 6px 0 0;
    letter-spacing: 0.04em;
    text-align: right;
  }

  .entry-cue {
    position: absolute;
    bottom: 18px;
    left: 50%;
    display: grid;
    justify-items: center;
    gap: 9px;
    color: var(--color-faint);
    opacity: 0;
    transform: translateX(-50%) translateY(12px);
  }

  .entry-line {
    width: 1px;
    height: 0;
    background: var(--color-accent-soft);
  }

  .entry-label {
    opacity: 0;
    transform: translateY(5px);
    font-size: 0.55rem;
    letter-spacing: 0.22em;
    white-space: nowrap;
  }

  .is-complete .terminal-window {
    animation: none;
    opacity: 1;
    transform: none;
  }

  .is-complete .terminal-cursor {
    opacity: 0;
  }

  .is-complete .entry-cue {
    opacity: 1;
    transform: translateX(-50%);
  }

  .is-complete .entry-line {
    animation:
      line-grow 2.5s cubic-bezier(0.22, 0.7, 0.28, 1) forwards,
      line-bob 2.4s ease-in-out 2.5s infinite;
  }

  .is-complete .entry-label {
    animation: label-reveal 900ms ease 2s forwards;
  }

  .intro-skip {
    position: absolute;
    right: clamp(24px, 5vw, 72px);
    bottom: 34px;
    border: 0;
    border-bottom: 1px solid transparent;
    padding: 3px 0;
    background: transparent;
    color: var(--color-faint);
    font-family: var(--font-sans);
    font-size: 0.68rem;
    cursor: pointer;
  }

  .intro-skip:hover {
    border-color: var(--color-faint);
    color: var(--color-text);
  }

  @keyframes terminal-enter {
    to {
      opacity: 1;
      transform: none;
    }
  }

  @keyframes cursor-blink {
    0%, 48% { opacity: 1; }
    49%, 100% { opacity: 0; }
  }

  @keyframes line-grow {
    to { height: 54px; }
  }

  @keyframes line-bob {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(4px); }
  }

  @keyframes label-reveal {
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 720px) {
    .intro-stage {
      min-height: 560px;
    }

    .terminal-window {
      width: calc(100vw - 36px);
      height: min(72svh, 540px);
      min-height: 470px;
    }

    .terminal-titlebar {
      grid-template-columns: 1fr auto 1fr;
      padding-inline: 12px;
    }

    .terminal-title {
      font-size: 0.58rem;
    }

    .terminal-body {
      padding: 22px 16px 20px;
    }

    .terminal-command {
      font-size: 0.62rem;
    }

    .terminal-session {
      -webkit-mask-image: linear-gradient(to bottom, transparent 0, #000 18px);
      mask-image: linear-gradient(to bottom, transparent 0, #000 18px);
    }

    .terminal-output-line {
      font-size: 0.58rem;
      line-height: 1.5;
    }

    .terminal-status {
      margin-top: 5px;
      font-size: 0.56rem;
    }

    .intro-kicker {
      top: 24px;
    }

    .intro-skip {
      right: 22px;
      bottom: 24px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .intro-stage,
    .terminal-window,
    .terminal-cursor,
    .entry-cue,
    .entry-line,
    .entry-label {
      animation: none !important;
      transition: none !important;
    }

    .terminal-window {
      opacity: 1;
      transform: none;
    }

    .is-complete .entry-cue {
      opacity: 1;
      transform: translateX(-50%);
    }

    .is-complete .entry-line {
      height: 54px;
    }

    .is-complete .entry-label {
      opacity: 1;
      transform: none;
    }
  }
</style>
