---
import BaseLayout from "@layouts/BaseLayout.astro";
import PostCard from "@components/PostCard.astro";
import { getAllTags, getPostsByTag, getPublishedPosts, type BlogPost } from "@utils/posts";

export async function getStaticPaths() {
  const posts = await getPublishedPosts();

  return getAllTags(posts).map((tag) => ({
    params: { tag },
    props: { tag, posts: getPostsByTag(posts, tag) },
  }));
}

interface Props {
  tag: string;
  posts: BlogPost[];
}

const { tag, posts } = Astro.props;
---

<BaseLayout title={`标签：${tag}`} description={`Akisy 博客中带有 ${tag} 标签的文章。`}>
  <header class="page-header">
    <p class="eyebrow">Tag</p>
    <h1>{tag}</h1>
    <p>共 {posts.length} 篇文章。</p>
  </header>

  <div class="post-list">
    {posts.map((post) => <PostCard post={post} />)}
  </div>
</BaseLayout>
