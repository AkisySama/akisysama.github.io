---
import BaseLayout from "@layouts/BaseLayout.astro";
import PostCard from "@components/PostCard.astro";
import { getPublishedPosts } from "@utils/posts";

const posts = await getPublishedPosts();
const latestPosts = posts.slice(0, 5);
---

<BaseLayout>
  <section class="hero" aria-labelledby="home-title">
    <div>
      <p class="eyebrow">Personal Blog</p>
      <h1 id="home-title">Akisy的记录</h1>
      <p>
        这里记录一些技术笔记、生活片段、历史阅读和旅途中的想法。新站点从 Hexo
        迁移到 Astro，先把阅读体验打稳，再慢慢长出更多功能。
      </p>
    </div>
    <img src="/images/whitehairblueeyes.jpeg" alt="Akisy 的头像" width="220" height="220" />
  </section>

  <section aria-labelledby="latest-posts">
    <div class="section-heading">
      <h2 id="latest-posts">最新文章</h2>
      <a href="/posts/">查看全部</a>
    </div>
    <div class="post-grid">
      {latestPosts.map((post) => <PostCard post={post} />)}
    </div>
  </section>
</BaseLayout>
