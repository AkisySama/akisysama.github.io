---
import BaseLayout from "@layouts/BaseLayout.astro";
import IntroSequence from "@components/IntroSequence.astro";
import {
  ArrowRight,
  Camera,
  CodeXml,
  NotebookPen,
} from "@lucide/astro";
import { formatDate } from "@utils/dates";
import { getPostDescription, getPostUrl, getPublishedPosts } from "@utils/posts";
import { pathForTag } from "@utils/slug";

const posts = await getPublishedPosts();
const featuredPosts = posts.slice(0, 3);
const journalPost = posts[0];

const focusItems = [
  {
    icon: CodeXml,
    title: "技术手记",
    description: "我真的有技术吗？",
    linkLabel: "探索技术",
    href: pathForTag("技术"),
  },
  {
    icon: Camera,
    title: "生活片段",
    description: "随便拍的和碎碎念",
    linkLabel: "翻阅生活",
    href: pathForTag("回忆"),
  },
  {
    icon: NotebookPen,
    title: "随想与阅读",
    description: "大概率是睡不着的胡思乱想",
    linkLabel: "阅读随想",
    href: pathForTag("历史"),
  },
];

const selectedImages = [
  { src: "/images/209169A8-B52A-4BA1-8F9E-B009E467288E_4_5005_c.jpeg", alt: "海边旅行照片" },
  { src: "/images/my university/1.jpeg", alt: "大学时的摩天轮照片" },
  { src: "/images/my university/4.jpeg", alt: "辽阔平原风景" },
  { src: "/assets/ring.webp", alt: "夜色中的奇幻风景" },
];

const signalNodes = [
  { x: 48, mobileX: 11, y: 40 },
  { x: 56, mobileX: 25, y: 62 },
  { x: 64, mobileX: 39, y: 25 },
  { x: 72, mobileX: 53, y: 48 },
  { x: 80, mobileX: 68, y: 70 },
  { x: 88, mobileX: 82, y: 35 },
  { x: 94, mobileX: 93, y: 58 },
];
---

<BaseLayout>
  <IntroSequence slot="intro" />

  <section class="editorial-hero" aria-labelledby="home-title">
    <div class="hero-copy">
      <p class="hero-greeting"></p>
      <h1 id="home-title">Akisy.</h1>
      <p class="hero-intro">
        这是我在互联网上的一片孤岛,创建于2024年3月26日
      </p>
    </div>

    <figure class="hero-portrait" aria-label="数字孤岛信号图主视觉">
      <img
        src="/images/digital-island-signal.webp"
        alt="由等高线、信号节点与扫描轨迹组成的数字孤岛"
        width="1774"
        height="887"
        loading="eager"
      />
      <span class="hero-signal-field" data-signal-field aria-hidden="true">
        {
          signalNodes.map(({ x, mobileX, y }) => (
            <i style={`--signal-x:${x}%;--signal-mobile-x:${mobileX}%;--signal-y:${y}%`}></i>
          ))
        }
      </span>
      <figcaption>SIGNAL FOUND / AKISY’S JOURNAL</figcaption>
    </figure>
  </section>

  <section class="focus-strip" aria-labelledby="focus-title">
    <p class="vertical-label" id="focus-title">FOCUS</p>
    <div class="focus-grid">
      {
        focusItems.map(({ icon: Icon, title, description, linkLabel, href }) => (
          <article class="focus-item">
            <span class="focus-icon" aria-hidden="true">
              <Icon size={23} stroke-width={1.25} />
            </span>
            <div>
              <h2>{title}</h2>
              <p>{description}</p>
              <a class="text-link" href={href}>
                {linkLabel}
                <ArrowRight size={15} stroke-width={1.35} aria-hidden="true" />
              </a>
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <section class="editorial-grid" aria-label="博客精选内容">
    <div class="featured-list">
      <div class="editorial-heading">
        <span>精选文章</span>
        <i aria-hidden="true"></i>
      </div>
      <ol>
        {
          featuredPosts.map((post, index) => (
            <li>
              <span class="article-index">{String(index + 1).padStart(2, "0")}</span>
              <div>
                <h2><a href={getPostUrl(post)}>{post.data.title}</a></h2>
                <p>{getPostDescription(post)}</p>
                <p class="article-meta">
                  <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
                  <span>·</span>
                  <span>{Math.max(3, Math.round((post.body?.length ?? 0) / 650))} 分钟阅读</span>
                </p>
              </div>
              <ArrowRight class="article-arrow" size={16} stroke-width={1.3} aria-hidden="true" />
            </li>
          ))
        }
      </ol>
    </div>

    <div class="journal-feature">
      <div class="editorial-heading">
        <span>最新记录</span>
        <i aria-hidden="true"></i>
      </div>
      {
        journalPost && (
          <a
            class="journal-card"
            href={getPostUrl(journalPost)}
            aria-label={`阅读 ${journalPost.data.title}`}
          >
            <img src={journalPost.data.cover ?? "/images/default-post-cover.jpeg"} alt="" loading="lazy" />
            <div class="journal-card-overlay">
              <time datetime={journalPost.data.pubDate.toISOString()}>{formatDate(journalPost.data.pubDate)}</time>
              <h2>{journalPost.data.title}</h2>
              <p>{getPostDescription(journalPost)}</p>
              <span class="text-link">
                继续阅读
                <ArrowRight size={15} stroke-width={1.35} aria-hidden="true" />
              </span>
            </div>
          </a>
        )
      }
    </div>

    <div class="photo-selection">
      <div class="editorial-heading">
        <span>片刻收藏</span>
        <i aria-hidden="true"></i>
      </div>
      <div class="photo-grid">
        {selectedImages.map((image) => <img src={image.src} alt={image.alt} loading="lazy" />)}
      </div>
      <a class="text-link" href="/posts/">
        浏览全部记录
        <ArrowRight size={15} stroke-width={1.35} aria-hidden="true" />
      </a>
    </div>
  </section>
</BaseLayout>

<script>
  const setupSignalField = () => {
    document.querySelectorAll<HTMLElement>("[data-signal-field]").forEach((field) => {
      if (field.dataset.bound === "true") return;
      field.dataset.bound = "true";

      const nodes = Array.from(field.querySelectorAll<HTMLElement>("i"));
      const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");

      const schedulePulse = () => {
        if (!field.isConnected || reducedMotion.matches) return;

        const available = [...nodes];
        const activeCount = Math.random() > 0.72 ? 2 : 1;

        for (let index = 0; index < activeCount; index += 1) {
          const selectedIndex = Math.floor(Math.random() * available.length);
          const node = available.splice(selectedIndex, 1)[0];
          const duration = 1050 + Math.random() * 650;

          node.style.setProperty("--signal-duration", `${duration}ms`);
          node.classList.remove("is-active");
          void node.offsetWidth;
          node.classList.add("is-active");
          window.setTimeout(() => node.classList.remove("is-active"), duration);
        }

        window.setTimeout(schedulePulse, 900 + Math.random() * 1900);
      };

      window.setTimeout(schedulePulse, 700 + Math.random() * 900);
    });
  };

  document.addEventListener("astro:page-load", setupSignalField);
  setupSignalField();
</script>
