---
import { ClientRouter } from "astro:transitions";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import "@styles/global.css";

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const siteTitle = "Akisy的记录";
const defaultDescription = "Akisy 的个人博客，记录技术、生活、历史和路上的想法。";
const { title = siteTitle, description = defaultDescription, image } = Astro.props;
const pageTitle = title === siteTitle ? title : `${title} | ${siteTitle}`;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const ogImage = image ? new URL(image, Astro.site).toString() : undefined;
const isHome = Astro.url.pathname === "/";
---

<!doctype html>
<html
  lang="zh-CN"
  data-page={isHome ? "home" : "inner"}
  data-intro={isHome ? "pending" : undefined}
>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <script is:inline>
      (() => {
        const root = document.documentElement;
        const isHomePage = root.dataset.page === "home";

        if (isHomePage) {
          if ("scrollRestoration" in history) history.scrollRestoration = "manual";

          const resetIntroScroll = () => {
            if (root.dataset.intro === "pending" || root.dataset.intro === "playing") {
              window.scrollTo({ top: 0, left: 0, behavior: "auto" });
            }
          };

          resetIntroScroll();
          window.addEventListener("pageshow", resetIntroScroll);
          window.addEventListener("load", resetIntroScroll, { once: true });
          window.addEventListener("beforeunload", () => window.scrollTo(0, 0), { capture: true });
        }

        let savedTheme = null;

        try {
          savedTheme = localStorage.getItem("akisy-theme");
        } catch {
          // Storage can be unavailable in privacy-restricted contexts.
        }

        const theme = savedTheme === "light" || savedTheme === "dark" ? savedTheme : "dark";

        root.dataset.theme = theme;
        root.style.colorScheme = theme;

      })();
    </script>
    <ClientRouter />
  </head>
  <body>
    <slot name="intro" />
    <Header />
    <main class="site-main">
      <slot />
    </main>
    <Footer />
  </body>
</html>
