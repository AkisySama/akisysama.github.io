---
import { ClientRouter } from "astro:transitions";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import "@styles/global.css";

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const siteTitle = "Akisy的记录";
const defaultDescription = "Akisy 的个人博客，记录技术、生活、历史和路上的想法。";
const { title = siteTitle, description = defaultDescription, image } = Astro.props;
const pageTitle = title === siteTitle ? title : `${title} | ${siteTitle}`;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const ogImage = image ? new URL(image, Astro.site).toString() : undefined;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <script is:inline>
      (() => {
        let savedTheme = null;

        try {
          savedTheme = localStorage.getItem("akisy-theme");
        } catch {
          // Storage can be unavailable in privacy-restricted contexts.
        }

        const theme =
          savedTheme === "light" || savedTheme === "dark"
            ? savedTheme
            : matchMedia("(prefers-color-scheme: dark)").matches
              ? "dark"
              : "light";

        document.documentElement.dataset.theme = theme;
        document.documentElement.style.colorScheme = theme;
      })();
    </script>
    <ClientRouter />
  </head>
  <body>
    <Header />
    <main class="site-main">
      <slot />
    </main>
    <Footer />
  </body>
</html>
