---
import TagList from "@components/TagList.astro";
import { Calendar, Clock } from "@lucide/astro";
import { formatDate, toDateTime } from "@utils/dates";
import { getPostCover, type BlogPost } from "@utils/posts";

interface Props {
  post: BlogPost;
}

const { post } = Astro.props;
const cover = getPostCover(post);
---

<article class="post-detail">
  <header class="post-hero">
    <p class="eyebrow">文章</p>
    <h1>{post.data.title}</h1>
    <div class="post-meta">
      <time datetime={toDateTime(post.data.pubDate)}>
        <Calendar class="icon-muted" size={16} stroke-width={1.8} />
        发布于 {formatDate(post.data.pubDate)}
      </time>
      {
        post.data.updatedDate && (
          <time datetime={toDateTime(post.data.updatedDate)}>
            <Clock class="icon-muted" size={16} stroke-width={1.8} />
            更新于 {formatDate(post.data.updatedDate)}
          </time>
        )
      }
    </div>
    <TagList tags={post.data.tags} />
    <img class="post-cover" src={cover} alt="" loading="eager" />
  </header>
  <div class="prose">
    <slot />
  </div>
</article>
